@model FaithTrack.Models.Category

@{
    ViewData["Title"] = "View Category";
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Category" asp-action="Index">Categories</a>
            </li>
            <li class="breadcrumb-item active">View Category</li>
        </ol>
    </nav>
    <div class="d-flex justify-content-between align-items-center">
        <h2 class="fw-bold text-primary">
            <i class="bi bi-tag me-2"></i>View Category
        </h2>
        <a asp-action="Edit" asp-route-id="@Model.CategoryId"
           class="btn btn-outline-warning">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-4">

        <div class="mb-3">
            <label class="form-label text-uppercase text-muted small fw-bold">
                Category Name:
            </label>
            <div class="form-control bg-light">@Model.Name</div>
        </div>

        <div class="mb-4">
            <label class="form-label text-uppercase text-muted small fw-bold">
                Description:
            </label>
            <div class="form-control bg-light" style="min-height:80px;">
                @(string.IsNullOrWhiteSpace(Model.Description)
                    ? "No description provided."
                    : Model.Description)
            </div>
        </div>

        <!-- Show resources in this category -->
        @if (Model.Resources != null && Model.Resources.Any())
        {
            <div class="border-top pt-3">
                <label class="form-label text-uppercase text-muted small fw-bold">
                    Resources in this Category:
                </label>
                <ul class="list-group list-group-flush">
                    @foreach (var resource in Model.Resources)
                    {
                        <li class="list-group-item">
                            <i class="bi bi-file-text me-2 text-primary"></i>
                            @resource.Title
                        </li>
                    }
                </ul>
            </div>
        }

    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-primary">
        <i class="bi bi-arrow-left me-1"></i>Back to Categories
    </a>
</div>
