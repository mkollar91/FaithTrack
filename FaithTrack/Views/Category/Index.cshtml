@*
    FaithTrack — Views/Category/Index.cshtml
    Category List page. Sprint 2 — US-8: View list of categories.
    Shows all categories with Add, Edit, Delete action buttons.

    Author  : Matthew Kollar
    Course  : CST-452 — Grand Canyon University
*@
@model IEnumerable<FaithTrack.Models.Category>

@{
    ViewData["Title"] = "Categories";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary">
        <i class="bi bi-tags me-2"></i>Categories
    </h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle me-1"></i>+ Add Category
    </a>
</div>

@if (!Model.Any())
{
    <div class="card shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-tags display-4 text-muted mb-3 d-block"></i>
            <h5 class="text-muted">No categories yet</h5>
            <p class="text-muted">Click "+ Add Category" to create your first category.</p>
            <a asp-action="Create" class="btn btn-primary mt-2">
                <i class="bi bi-plus-circle me-1"></i>Add Your First Category
            </a>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-primary">
                    <tr>
                        <th scope="col">Category Name</th>
                        <th scope="col">Description</th>
                        <th scope="col" class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var category in Model)
                    {
                        <tr>
                            <td class="align-middle fw-semibold">
                                @category.Name
                            </td>
                            <td class="align-middle text-muted">
                                @(string.IsNullOrWhiteSpace(category.Description)
                                    ? "No description provided."
                                    : category.Description)
                            </td>
                            <td class="align-middle text-center">
                                <a asp-action="Details"
                                   asp-route-id="@category.CategoryId"
                                   class="btn btn-outline-primary btn-sm me-1">
                                    <i class="bi bi-eye me-1"></i>View
                                </a>
                                <a asp-action="Edit"
                                   asp-route-id="@category.CategoryId"
                                   class="btn btn-outline-warning btn-sm me-1">
                                    <i class="bi bi-pencil me-1"></i>Edit
                                </a>
                                <a asp-action="Delete"
                                   asp-route-id="@category.CategoryId"
                                   class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-trash me-1"></i>Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer text-muted small text-end">
            Showing @Model.Count() category(ies)
        </div>
    </div>
}
