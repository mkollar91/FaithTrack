<!DOCTYPE html>
<!--
    FaithTrack — Views/Shared/_Layout.cshtml
    Shared layout for all pages. Implements the consistent
    navigation bar shown across all wireframes in the
    Architecture Plan (Figs. 8–14) and the Sitemap (Fig. 7).
    Navigation: Resources | Categories | Profile | Logout
    Uses Bootstrap 5 for responsive styling.

    Author  : Matthew Kollar
    Course  : CST-451 — Grand Canyon University
-->
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — FaithTrack</title>

    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <!-- FaithTrack custom styles -->
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <!-- ═══════════════════════════════════════════════════════
         Navigation Bar
         Matches the persistent nav bar shown in all wireframes
         (Architecture Plan Figs. 8–14) and Sitemap (Fig. 7).
         Displays: FaithTrack brand | Resources | Categories |
                   Profile | Logout (authenticated users)
         ═══════════════════════════════════════════════════════ -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">

            <!-- Brand / Logo -->
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="bi bi-book-half me-1"></i> FaithTrack
            </a>

            <!-- Mobile hamburger toggle -->
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">

                @* Show nav links only when authenticated *@
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <ul class="navbar-nav me-auto">
                        <!-- Resources — US-4: View Resource List (Sprint 1) -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Resources" asp-action="Index">
                                <i class="bi bi-collection me-1"></i>Resources
                            </a>
                        </li>
                        <!-- Categories — US-8: View Categories (Sprint 2) -->
                        <li class="nav-item">
                            <a class="nav-link text-warning" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-tags me-1"></i>Categories
                                <small class="badge bg-warning text-dark ms-1">Sprint 2</small>
                            </a>
                        </li>
                    </ul>

                    <!-- Right side: user email + logout -->
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <span class="nav-link text-light">
                                <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                            </span>
                        </li>
                        <li class="nav-item">
                            <!-- Logout uses POST to prevent CSRF (NFR Security p.26) -->
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm ms-2">
                                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                }
                else
                {
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
                        </li>
                    </ul>
                }

            </div>
        </div>
    </nav>

    <!-- ═══════════════════════════════════════════════════════
         Main Content Area
         ═══════════════════════════════════════════════════════ -->
    <main class="container my-4">

        <!-- Global success / error flash messages -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </main>

    <!-- ═══════════════════════════════════════════════════════
         Footer
         ═══════════════════════════════════════════════════════ -->
    <footer class="footer mt-auto py-3 bg-light border-top">
        <div class="container text-center text-muted small">
            FaithTrack &copy; 2026 &mdash; Matthew Kollar &mdash; CST-451 Capstone &mdash; Grand Canyon University
        </div>
    </footer>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
