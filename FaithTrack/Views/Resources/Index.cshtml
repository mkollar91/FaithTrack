@*
    FaithTrack — Views/Resources/Index.cshtml
    Resources List page. Implements Architecture Plan
    Figure 10 (Resources List Wireframe):
      - Page title "Resources" with "+ Add Resource" button
      - Table: Title | Category | Date Added | Actions
      - Action buttons: View | Edit | Delete per row
    User Story 4 (Sprint 1): View a list of faith-based resources.

    Author  : Matthew Kollar
    Course  : CST-451 — Grand Canyon University
*@
@model IEnumerable<FaithTrack.ViewModels.ResourceViewModel>

@{
    ViewData["Title"] = "Resources";
}

<!-- Page Header — matches Fig. 10 wireframe -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary">
        <i class="bi bi-collection me-2"></i>Resources
    </h2>
    <!-- "+ Add Resource" button — matches Fig. 10 wireframe -->
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle me-1"></i>+ Add Resource
    </a>
</div>

@if (!Model.Any())
{
    <!-- Empty state — shown when user has no resources yet -->
    <div class="card shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-collection display-4 text-muted mb-3 d-block"></i>
            <h5 class="text-muted">No resources yet</h5>
            <p class="text-muted">Click "+ Add Resource" to create your first faith-based resource.</p>
            <a asp-action="Create" class="btn btn-primary mt-2">
                <i class="bi bi-plus-circle me-1"></i>Add Your First Resource
            </a>
        </div>
    </div>
}
else
{
    <!-- Resources Table — matches Fig. 10 wireframe layout:
         Title | Category | Date Added | Actions (View/Edit/Delete) -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-primary">
                    <tr>
                        <th scope="col">Title</th>
                        <th scope="col">Category</th>
                        <th scope="col">Date Added</th>
                        <th scope="col" class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var resource in Model)
                    {
                        <tr>
                            <td class="align-middle fw-semibold">
                                @resource.Title
                            </td>
                            <td class="align-middle">
                                <span class="badge bg-secondary">@resource.CategoryName</span>
                            </td>
                            <td class="align-middle text-muted small">
                                @resource.CreatedDate.ToString("MM/dd/yyyy")
                            </td>
                            <!-- Action buttons: View | Edit | Delete — matches Fig. 10 -->
                            <td class="align-middle text-center">
                                <a asp-action="Details"
                                   asp-route-id="@resource.ResourceId"
                                   class="btn btn-outline-primary btn-sm me-1">
                                    <i class="bi bi-eye me-1"></i>View
                                </a>
                                <a asp-action="Edit"
                                   asp-route-id="@resource.ResourceId"
                                   class="btn btn-outline-warning btn-sm me-1">
                                    <i class="bi bi-pencil me-1"></i>Edit
                                </a>
                                <a asp-action="Delete"
                                   asp-route-id="@resource.ResourceId"
                                   class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-trash me-1"></i>Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer text-muted small text-end">
            Showing @Model.Count() resource(s)
        </div>
    </div>
}
