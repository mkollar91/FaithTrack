@*
    FaithTrack — Views/Resources/Edit.cshtml
    Edit Resource form. Implements Architecture Plan
    Figure 12 (Edit Resource Wireframe):
      - All fields pre-populated with current resource values
      - Title, Category, Description, URL editable
      - Save Changes and Cancel buttons
    User Story 6 (Sprint 1): Edit an existing resource.

    Author  : Matthew Kollar
    Course  : CST-451 — Grand Canyon University
*@
@model FaithTrack.ViewModels.ResourceViewModel

@{
    ViewData["Title"] = "Edit Resource";
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Resource" asp-action="Index">Resources</a>
            </li>
            <li class="breadcrumb-item active">Edit Resource</li>
        </ol>
    </nav>
    <h2 class="fw-bold text-primary">
        <i class="bi bi-pencil-square me-2"></i>Edit Resource
    </h2>
</div>

<div class="card shadow-sm">
    <div class="card-body p-4">

        <div asp-validation-summary="ModelOnly"
             class="alert alert-danger"
             style="display:@(ViewContext.ModelState.IsValid ? "none" : "block")">
        </div>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <!-- Hidden field preserves the ResourceId for the POST action -->
            <input type="hidden" asp-for="ResourceId" />

            <!-- Title — pre-populated per Fig. 12 wireframe -->
            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-semibold">
                    Title: <span class="text-danger">*</span>
                </label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <!-- Category Dropdown — pre-selected per Fig. 12 wireframe -->
            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label fw-semibold">
                    Category: <span class="text-danger">*</span>
                </label>
                <select asp-for="CategoryId"
                        asp-items="Model.Categories"
                        class="form-select">
                    <option value="">-- Select a category --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger small"></span>
            </div>

            <!-- Description — pre-populated per Fig. 12 wireframe -->
            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold">
                    Description: <span class="text-danger">*</span>
                </label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <!-- URL — pre-populated per Fig. 12 wireframe -->
            <div class="mb-4">
                <label asp-for="Url" class="form-label fw-semibold">
                    Resource URL / Reference:
                    <span class="text-muted fw-normal">(optional)</span>
                </label>
                <input asp-for="Url" class="form-control" />
                <span asp-validation-for="Url" class="text-danger small"></span>
            </div>

            <small class="text-muted d-block mb-3">
                <span class="text-danger">*</span> Required Fields
            </small>

            <!-- Save Changes / Cancel — matches Fig. 12 wireframe -->
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success px-4">
                    <i class="bi bi-floppy me-1"></i>Save Changes
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    Cancel
                </a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
