@*
    FaithTrack — Views/Resources/Delete.cshtml
    Delete Confirmation page. Implements Architecture Plan
    Figure 14 (Delete Confirmation Wireframe):
      - Warning header "Delete Resource"
      - Resource title, category, date displayed
      - "This action cannot be undone!" message
      - Cancel and Delete Permanently buttons
    User Story 7 (Sprint 1): Delete a resource with confirmation.

    Author  : Matthew Kollar
    Course  : CST-451 — Grand Canyon University
*@
@model FaithTrack.ViewModels.ResourceViewModel

@{
    ViewData["Title"] = "Delete Resource";
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Resource" asp-action="Index">Resources</a>
            </li>
            <li class="breadcrumb-item active">Delete Resource</li>
        </ol>
    </nav>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">

        <!-- Delete Confirmation Card — matches Fig. 14 wireframe modal -->
        <div class="card border-danger shadow">
            <div class="card-header bg-danger text-white text-center">
                <h4 class="mb-0">
                    <i class="bi bi-exclamation-triangle me-2"></i>Delete Resource
                </h4>
            </div>
            <div class="card-body text-center p-4">

                <!-- Warning icon and message — matches Fig. 14 wireframe -->
                <div class="bg-danger bg-opacity-10 rounded-circle d-inline-flex
                            align-items-center justify-content-center mb-3"
                     style="width:60px; height:60px;">
                    <i class="bi bi-exclamation-circle text-danger fs-3"></i>
                </div>

                <p class="fw-semibold">Are you sure you want to delete this resource?</p>

                <!-- Resource details — matches Fig. 14 wireframe info block -->
                <div class="card bg-light border mb-3 text-start">
                    <div class="card-body">
                        <p class="mb-1 fw-bold">@Model.Title</p>
                        <p class="mb-1 text-muted small">
                            Category: @Model.CategoryName
                        </p>
                        <p class="mb-0 text-muted small">
                            Added: @Model.CreatedDate.ToString("MM/dd/yyyy")
                        </p>
                    </div>
                </div>

                <!-- "Cannot be undone" warning — matches Fig. 14 wireframe -->
                <p class="text-danger fw-semibold">
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    This action cannot be undone!
                </p>

                <!-- Cancel / Delete Permanently — matches Fig. 14 wireframe -->
                <div class="d-flex gap-3 justify-content-center mt-3">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        Cancel
                    </a>
                    <form asp-action="Delete" asp-route-id="@Model.ResourceId" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash me-1"></i>Delete Permanently
                        </button>
                    </form>
                </div>

            </div>
        </div>

    </div>
</div>
