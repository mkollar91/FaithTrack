@*
    FaithTrack — Views/Home/Index.cshtml
    Dashboard — the primary landing page after login.
    Implements Architecture Plan Figure 9 (Dashboard Wireframe):
      - "Welcome to FaithTrack" heading
      - Quick Access panel: Resources (Go to Resources button)
      - Quick Access panel: Categories (Go to Categories button)
    Navigation bar provided by _Layout.cshtml (Fig. 7 Sitemap).

    Author  : Matthew Kollar
    Course  : CST-451 — Grand Canyon University
*@

@{
    ViewData["Title"] = "Dashboard";
}

<!-- Welcome Heading — matches Fig. 9 Dashboard wireframe -->
<div class="text-center py-4 mb-4 bg-primary text-white rounded">
    <h2 class="fw-bold">
        <i class="bi bi-house-heart me-2"></i>Welcome to FaithTrack
    </h2>
    <p class="mb-0">Hello, @User.Identity?.Name — manage your faith-based resources below.</p>
</div>

<h5 class="text-muted mb-3">Quick Access</h5>

<!-- Quick Access Panels — matches Fig. 9 Dashboard wireframe -->
<div class="row g-4">

    <!-- Resources Panel — US-4 (Sprint 1) -->
    <div class="col-md-6">
        <div class="card h-100 shadow-sm border-primary">
            <div class="card-body text-center py-5">
                <i class="bi bi-collection display-4 text-primary mb-3 d-block"></i>
                <h4 class="card-title fw-bold">Resources</h4>
                <p class="card-text text-muted">
                    View and manage your faith-based resources
                </p>
                <a asp-controller="Resources" asp-action="Index"
                   class="btn btn-primary mt-2">
                    <i class="bi bi-arrow-right-circle me-1"></i>Go to Resources
                </a>
            </div>
        </div>
    </div>

    <!-- Categories Panel — US-8 (Sprint 2) -->
    <div class="col-md-6">
        <div class="card h-100 shadow-sm border-warning">
            <div class="card-body text-center py-5">
                <i class="bi bi-tags display-4 text-warning mb-3 d-block"></i>
                <h4 class="card-title fw-bold">Categories</h4>
                <p class="card-text text-muted">
                    Organize content by categories and topics
                </p>
                <a href="#"
                   class="btn btn-warning mt-2 disabled"
                   aria-disabled="true">
                    <i class="bi bi-arrow-right-circle me-1"></i>Go to Categories
                    <small class="badge bg-dark ms-1">Sprint 2</small>
                </a>
            </div>
        </div>
    </div>

</div>

<!-- Sprint status note -->
<div class="alert alert-info mt-4" role="alert">
    <i class="bi bi-info-circle me-2"></i>
    <strong>Sprint 1 Complete:</strong> Login, Dashboard, and full Resource management (Create, View, Edit, Delete) are implemented.
    Categories, Search, and Registration are planned for <strong>Sprint 2</strong>.
</div>
